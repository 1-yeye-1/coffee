# Runtime
NODE_ENV=development
SERVER_PORT=4173

# Database. The project enforces DB_NAME=coffee.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=coffee
DB_USER=your_user
DB_PASSWORD=your_password

# Auth. Use a long random value in production.
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated allowed browser origins for the API.
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# Optional smoke-test credentials. Keep real secrets in .env only.
SMOKE_ADMIN_USERNAME=admin
SMOKE_ADMIN_PASSWORD=admin123456
