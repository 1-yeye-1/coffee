{
  "name": "coffee-book",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --config apps/web/vite.config.js",
    "dev:admin": "vite --config apps/admin/vite.config.js",
    "dev:server": "node server/index.js",
    "dev:all": "node scripts/dev-all.js",
    "build:web": "vite build --config apps/web/vite.config.js",
    "build:admin": "vite build --config apps/admin/vite.config.js",
    "build": "npm run build:web && npm run build:admin",
    "preview:web": "vite preview --config apps/web/vite.config.js",
    "preview:admin": "vite preview --config apps/admin/vite.config.js",
    "start": "node server/index.js",
    "server": "node server/index.js",
    "db:init": "node server/db/migrate.js && node server/db/seed.js && node scripts/check-db-schema.js",
    "db:seed": "node server/db/seed.js",
    "db:check": "node scripts/check-db-schema.js",
    "test:request": "node scripts/test-request.js",
    "test:chunk": "node scripts/test-chunk-recovery.js",
    "check:motion": "node scripts/check-motion.js",
    "check": "npm run build && node scripts/check-project.js && npm run check:motion",
    "smoke:web": "node scripts/smoke-web.js",
    "smoke:api": "node scripts/run-api-smoke.js",
    "smoke": "npm run check && npm run test:request && npm run test:chunk && npm run smoke:web && npm run smoke:api"
  },
  "dependencies": {
    "animejs": "^4.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "pinia": "^3.0.3",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "vite": "^7.0.0"
  }
}
