# Runtime. 生产环境建议使用 production，本地开发可改为 development。
NODE_ENV=production
SERVER_PORT=4173

# Database. DB_NAME can be changed to another letters/numbers/underscores-only name.
# MySQL must be running and listening on DB_HOST:DB_PORT before db:init, dev:server, or smoke:api.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=coffee
DB_USER=your_user
DB_PASSWORD=your_password

# Auth. 生产环境必须替换为足够长的随机值，不要提交真实密钥。
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated allowed browser origins for the API.
# 生产环境请替换为前台和后台真实来源，例如：
# CORS_ORIGIN=https://your-web-domain.com,https://your-admin-domain.com
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# Optional smoke-test credentials. Keep real secrets in .env only.
SMOKE_ADMIN_USERNAME=admin
SMOKE_ADMIN_PASSWORD=admin123456
